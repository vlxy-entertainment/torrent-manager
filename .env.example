# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com/project/_/settings/api

# Supabase Project URL (public, can be exposed to client-side)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase Service Role Secret Key (server-side only)
# This key is NOT exposed to the browser. Use API routes for client-side operations.
SUPABASE_SECRET_KEY=your_supabase_service_role_secret_key

# Image Upload Endpoint
IMAGE_UPLOAD_ENDPOINT=your_image_upload_endpoint_url

# App base URL (public). Used by the CSV pipeline routes to build absolute URLs
# for self-referencing server-side fetches (the background process-job trigger and
# the internal /api/torrents call). Defaults to http://localhost:4000 when unset.
# Set this to the deployed origin in production (e.g. https://your-domain).
NEXT_PUBLIC_APP_URL=http://localhost:4000
